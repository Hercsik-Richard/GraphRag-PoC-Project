# ========================================
# DOCKER COMPOSE CONFIGURATION
# ========================================
# This file configures Docker Compose services.
# To use: cp .env.example .env
# ========================================

# PostgreSQL Configuration
APP_PG_USER=graphrag_user
APP_PG_PASSWORD=graphrag_pass123
APP_PG_DATABASE=graphrag_db
APP_PG_PORT=5432

# ========================================
# MODEL PROVIDER CONFIGURATION
# ========================================
# Choose your model provider: "ollama" (local) or "gemini" (Google API)
# Same provider is used for both indexing and querying to ensure embedding compatibility
# Default: ollama
APP_MODEL_PROVIDER=ollama

# ========================================
# OLLAMA CONFIGURATION (for local inference)
# ========================================
# Recommended on MacBook M2: install/run Ollama natively on macOS, then keep
# APP_OLLAMA_BASE_URL pointed at host.docker.internal so the backend container
# can reach the host Ollama service with Metal acceleration.
APP_OLLAMA_BASE_URL=http://host.docker.internal:11434
APP_OLLAMA_LLM_MODEL=qwen2.5:3b
APP_OLLAMA_EMBED_MODEL=nomic-embed-text

# ========================================
# GEMINI CONFIGURATION (for Google API)
# ========================================
# Required only when APP_MODEL_PROVIDER=gemini
# Get your API key from: https://aistudio.google.com/app/apikey
APP_GEMINI_API_KEY=
APP_GEMINI_LLM_MODEL=gemini-2.5-flash-lite
APP_GEMINI_EMBED_MODEL=gemini-embedding-001

# ========================================
# GRAPHRAG INDEXING CONTROLS
# ========================================
# Gemini indexing makes many LLM calls; these defaults favor reliability.
APP_GRAPHRAG_CONCURRENT_REQUESTS=1
APP_GRAPHRAG_MAX_RETRIES=8
APP_GRAPHRAG_MAX_RETRY_WAIT=60.0
APP_GRAPHRAG_INDEX_TIMEOUT_SECONDS=7200
APP_GRAPHRAG_REQUEST_TIMEOUT=600.0
APP_GRAPHRAG_CHUNK_SIZE=1600
APP_GRAPHRAG_CHUNK_OVERLAP=100
APP_GRAPHRAG_CLAIM_EXTRACTION_ENABLED=false

# Application Settings
APP_DEBUG=false
