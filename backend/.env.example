# ========================================
# LOCAL DEVELOPMENT CONFIGURATION
# ========================================
# This file is ONLY for running the backend locally WITHOUT Docker.
# If using Docker Compose, configure the root .env file instead.
#
# To use: cp .env.example .env.local
# ========================================

# PostgreSQL Database Configuration
# Connect to PostgreSQL running on your host (not in Docker)
APP_DATABASE_URL=postgresql://graphrag_user:graphrag_pass123@localhost:5432/graphrag_db

# ========================================
# MODEL PROVIDER CONFIGURATION
# ========================================
# Choose split providers for indexing/querying. Embedding provider/model must stay
# aligned between index and query for accurate retrieval. Default: all Ollama.
APP_MODEL_PROVIDER=ollama
APP_INDEX_CHAT_PROVIDER=ollama
APP_INDEX_EMBED_PROVIDER=ollama
APP_QUERY_CHAT_PROVIDER=ollama
APP_QUERY_EMBED_PROVIDER=ollama

# ========================================
# OLLAMA CONFIGURATION (for local inference)
# ========================================
# Required when APP_MODEL_PROVIDER=ollama
APP_OLLAMA_BASE_URL=http://localhost:11434

# LLM Model for chat (must be pulled in your local Ollama)
APP_OLLAMA_LLM_MODEL=gemma3:4b

# Embedding Model (must be pulled in your local Ollama)
APP_OLLAMA_EMBED_MODEL=nomic-embed-text

# ========================================
# GEMINI CONFIGURATION (for Google API)
# ========================================
# Required when APP_MODEL_PROVIDER=gemini
# Get your API key from: https://aistudio.google.com/app/apikey
# APP_GEMINI_API_KEY=your-gemini-api-key-here

# LLM Model for chat (default: gemini-3.1-flash-lite)
# APP_GEMINI_LLM_MODEL=gemini-3.1-flash-lite

# Embedding Model (default: gemini-embedding-2)
# Keep index and query embedding models identical. Switching from an older
# gemini-embedding-001 index requires full re-indexing.
# APP_GEMINI_EMBED_MODEL=gemini-embedding-2

# Conservative free-tier guard for Gemini query chat and embeddings.
# Keep this below the quota shown by the Gemini API response for your project.
APP_GEMINI_FREE_TIER_GUARD_ENABLED=true
APP_GEMINI_FREE_TIER_QUERY_RPM=7
APP_GEMINI_FREE_TIER_QUERY_TPM=120000
APP_GEMINI_FREE_TIER_QUERY_RPD=500
APP_GEMINI_FREE_TIER_INDEX_GUARD_ENABLED=true
APP_GEMINI_FREE_TIER_INDEX_RPM=7
APP_GEMINI_FREE_TIER_INDEX_TPM=120000
APP_GEMINI_FREE_TIER_INDEX_RPD=500
APP_GEMINI_FREE_TIER_EMBED_GUARD_ENABLED=true
APP_GEMINI_FREE_TIER_EMBED_RPM=100
APP_GEMINI_FREE_TIER_EMBED_TPM=30000
APP_GEMINI_FREE_TIER_EMBED_RPD=1000
APP_GEMINI_FREE_TIER_EMBED_BATCH_SIZE=16
APP_GEMINI_FREE_TIER_EMBED_BATCH_MAX_TOKENS=8191

# ========================================
# GRAPHRAG CONFIGURATION
# ========================================
APP_GRAPHRAG_ROOT=./ragtest
APP_GRAPHRAG_CHUNK_SIZE=1000
APP_GRAPHRAG_CHUNK_OVERLAP=150
APP_GRAPHRAG_CLEAN_OUTPUT_ON_INDEX=true
APP_GRAPHRAG_REPLACE_CORPUS_ON_UPLOAD=true

# ========================================
# FASTAPI CONFIGURATION
# ========================================
APP_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
APP_DEBUG=true

# ========================================
# EXAMPLE CONFIGURATIONS
# ========================================
#
# --- Scenario 1: Full Ollama (default, 100% local) ---
# APP_MODEL_PROVIDER=ollama
# APP_OLLAMA_BASE_URL=http://localhost:11434
# APP_OLLAMA_LLM_MODEL=gemma3:4b
# APP_OLLAMA_EMBED_MODEL=nomic-embed-text
#
# --- Scenario 2: Full Gemini (fast, cloud-based) ---
# APP_MODEL_PROVIDER=gemini
# APP_GEMINI_API_KEY=your-gemini-api-key
# APP_GEMINI_LLM_MODEL=gemini-3.1-flash-lite
# APP_GEMINI_EMBED_MODEL=gemini-embedding-2
#
# --- Scenario 3: Ollama indexing/embeddings, Gemini query chat ---
# APP_MODEL_PROVIDER=ollama
# APP_INDEX_CHAT_PROVIDER=ollama
# APP_INDEX_EMBED_PROVIDER=ollama
# APP_QUERY_CHAT_PROVIDER=gemini
# APP_QUERY_EMBED_PROVIDER=ollama
# APP_GEMINI_API_KEY=your-gemini-api-key
# APP_GEMINI_LLM_MODEL=gemini-3.1-flash-lite
#
# --- Scenario 4: Gemini indexing/query chat, Ollama embeddings ---
# APP_MODEL_PROVIDER=ollama
# APP_INDEX_CHAT_PROVIDER=gemini
# APP_INDEX_EMBED_PROVIDER=ollama
# APP_QUERY_CHAT_PROVIDER=gemini
# APP_QUERY_EMBED_PROVIDER=ollama
# APP_GEMINI_API_KEY=your-gemini-api-key
# APP_GEMINI_LLM_MODEL=gemini-3.1-flash-lite
# APP_GEMINI_FREE_TIER_INDEX_RPD=500
